# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=app.py

# Upload Configuration
MAX_FILE_SIZE=16777216
UPLOAD_FOLDER=uploads

# OCR Configuration
OCR_USE_GPU=False
OCR_LANGUAGE=en

# API Configuration
API_PORT=5001
API_HOST=0.0.0.0

# CORS Configuration — comma-separated origins, or "*" for open (dev only)
CORS_ORIGINS=*

# Specialist Finder (Google Maps Places API)
GOOGLE_MAPS_API_KEY=

# Analysis agent (OpenAI + PubMed)
OPENAI_API_KEY=
PUBMED_API_KEY=
