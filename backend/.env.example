# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=app.py

# Upload Configuration
MAX_FILE_SIZE=16777216  # 16MB in bytes
UPLOAD_FOLDER=uploads

# OCR Configuration
OCR_USE_GPU=False
OCR_LANGUAGE=en

# API Configuration
API_PORT=5000
API_HOST=0.0.0.0

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5000"]
